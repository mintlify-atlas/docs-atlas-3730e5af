  "keyFeatures": [
    "Board view for personalized content recommendations",
    "Discover page for browsing movies, series, channels, and more",
    "Personal library management with continue-watching tracking",
    "Built-in video player with subtitle support and external player options",
    "Extensible addon system for adding content sources",
    "Chromecast support for casting to TV",
    "Keyboard shortcuts for power users",
    "Calendar view for tracking upcoming episodes",
    "Search across all installed addons",
    "Docker support for self-hosting",
    "PWA (Progressive Web App) support",
    "Streaming server integration for local content"
